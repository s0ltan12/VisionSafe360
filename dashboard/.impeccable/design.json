  "narrative": {
    "northStar": "Command Center Vigilance",
    "overview": "This system is designed for sustained operational monitoring under pressure. The visual language prioritizes high legibility, fast scan paths, and immediate state recognition before decorative expression.\n\nThe tone is trustworthy, vigilant, and actionable. Surfaces stay dark and stable so signal colors carry operational meaning, not ornament. The system explicitly rejects flashy neon hacker aesthetics and novelty visuals that distract from incident response.",
    "keyCharacteristics": [
      "Dense but controlled information layout with clear hierarchy",
      "Orange as a deliberate action and attention signal",
      "Neutral-first framing with restrained emphasis colors",
      "Strong uppercase labeling for system status and control zones",
      "State clarity over visual spectacle"
    ],
    "rules": [
      {
        "name": "The Signal Scarcity Rule",
        "body": "Signal Orange is reserved for action, active state, and critical focus points. It is never used as decorative fill.",
        "section": "colors"
      },
      {
        "name": "The Status First Rule",
        "body": "Label typography must remain compact, uppercase, and high-contrast whenever it communicates state or severity.",
        "section": "typography"
      },
      {
        "name": "The Flat by Default Rule",
        "body": "Resting states stay flat and tonal. Elevation appears only to confirm interaction or direct action.",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do keep dark neutrals as the dominant surface system (#050505, #0A0A0A, #0F0F11) and reserve bright color for status and action.",
      "Do use clear severity mapping with redundant cues (color + label + shape).",
      "Do preserve compact uppercase labels for operational metadata and control groupings.",
      "Do keep interaction transitions brief and state-focused."
    ],
    "donts": [
      "Don't use flashy neon hacker aesthetics, novelty visual effects, or spectacle-first styling.",
      "Don't expand accent colors into broad decorative backgrounds that compete with safety signals.",
      "Don't introduce generic dashboard filler patterns that reduce operational intent.",
      "Don't rely on color alone for incident severity or system health communication."
    ]
  }

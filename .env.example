# Postgres
POSTGRES_DB=visionsafe360
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Backend
DATABASE_URL=postgresql+pg8000://postgres:change-me@db:5432/visionsafe360
SECRET_KEY=replace_with_a_minimum_32_char_high_entropy_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
LOG_LEVEL=INFO
LOG_JSON=true
AUDIT_LOG_PATH=backend/logs/audit.log
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
INCIDENT_RATE_LIMIT_PER_WINDOW=60
INCIDENT_RATE_LIMIT_WINDOW_SECONDS=60

# Frontend build-time settings
VITE_API_BASE_URL=http://localhost
VITE_WS_BASE_URL=

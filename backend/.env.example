DATABASE_URL=postgresql+pg8000://postgres:change-me@localhost:5432/visionsafe360
SECRET_KEY=replace_with_a_minimum_32_char_high_entropy_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
LOG_LEVEL=INFO
LOG_JSON=true
AUDIT_LOG_PATH=logs/audit.log
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
JOB_QUEUE_NAME=edge-worker
JOB_RETRY_MAX=3
INCIDENT_RATE_LIMIT_PER_WINDOW=60
INCIDENT_RATE_LIMIT_WINDOW_SECONDS=60
# Sentry error tracking (leave empty to disable)
# Get your DSN from: https://sentry.io/
SENTRY_DSN=
